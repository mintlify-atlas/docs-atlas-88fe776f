  "keyFeatures": [
    "Real-time collaborative data analysis with live presence",
    "AI agents with streaming step-by-step reasoning",
    "Natural language queries powered by Gemini",
    "DuckDB-powered vectorized OLAP analytics",
    "Live-updating charts and tables",
    "Query reproducibility and history tracking",
    "Automatic insights discovery",
    "Multi-user simultaneous querying",
    "Web scraping integration with Firecrawl",
    "CSV and SQL data import"
  ],
  "publicApiSurface": [
    "POST /api/duckdb/query - Execute DuckDB queries",
    "queryDuckDB(query: string) - Run SQL query on data",
    "getTableSchema(tableName: string) - Get table structure",
    "getSampleRows(tableName: string, limit: number) - Fetch sample data",
    "createChart(config: ChartConfig) - Generate visualizations",
    "generateInsights(data: any[]) - Auto-discover patterns",
    "firecrawlSearch(query: string) - Web search integration",
    "scrapeWebPage(url: string) - Extract web data",
    "analyzeDataQuality(tableName: string) - Data quality checks",
    "compareTables(table1: string, table2: string) - Compare datasets",
    "agentThreads table - Chat conversation storage",
    "agentMessages table - Message history",
    "queryLog table - Query execution history",
    "insightsCache table - Cached insights",
    "notifications table - Real-time notifications"
  ]
